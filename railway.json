{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "bash start.sh",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  },
  "checks": {
    "healthcheck": {
      "enabled": true,
      "endpoint": "/health",
      "method": "GET",
      "timeout": 30,
      "interval": 60,
      "startPeriod": 90,
      "maxRetries": 3
    }
  },
  "environments": {
    "production": {
      "variables": {
        "ENVIRONMENT": "production",
        "PYTHONUNBUFFERED": "1",
        "PYTHONPATH": ".",
        "PYTHON_VERSION": "3.9"
      }
    }
  },
  "scripts": {
    "postdeploy": "alembic upgrade head"
  }
}
